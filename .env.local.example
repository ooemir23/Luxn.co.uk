# Otelz API Configuration
# Copy this file to .env.local and fill in your Otelz credentials

REACT_APP_OTELZ_URL=https://api.otelz.com/v1
REACT_APP_OTELZ_KEY=your_otelz_api_key_here
REACT_APP_OTELZ_ENABLED=true

# Optional: Local development
# REACT_APP_OTELZ_ENABLED=false  # Use mock data for testing
